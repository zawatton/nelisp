#!/usr/bin/env bash
# anvil — Stage D Phase 6.0 launcher skeleton (bash, pre-Go/Rust port)
#
# Doc 18 Stage D LOCKED 2026-04-25。Option D = Hybrid CLI launcher。
# user config は $XDG_CONFIG_HOME/anvil/ (Doc 18 §2.9)、state DB は
# $XDG_CACHE_HOME/nelisp/nelisp-state.db (Doc 17 §2.2) を想定。
#
# Phase 6.0 時点では Emacs を user install 前提で検出 (Doc 18 §2.5 B)。
# Phase 6.2 (Doc 24) で anvil-http MVP port 完了 (tools/list 33)。
# Phase 6.3 で GitHub Release pipeline、Phase 6.4 で Windows 対応 (msys2
# mingw64 検出 + native Emacs path、bin/anvil.cmd wrapper)。

set -euo pipefail

ANVIL_VERSION="stage-d-v0.2-pre"

# Phase 7.5.1 (Doc 32 v2 LOCKED §2.6 + §3.1) — --strict-no-emacs flag
# scaffold.  v2.6 specifies that bin/anvil --no-emacs falls back to the
# host Emacs path on cold-init failure; --strict-no-emacs suppresses
# that fallback (CI / debugging use).
#
# Phase 7.5.2 (Doc 32 v2 LOCKED §3.2, this expansion) — wires the real
# cold-init invocation.  The launcher now:
#   1. parses --strict-no-emacs + --no-emacs (alias)
#   2. shells into emacs --batch with `nelisp-integration-cold-init-run'
#   3. on :status pass — proceeds with strict mode (today still falls
#      through to host Emacs since the static-linked binary lands in
#      Phase 7.5.3 stage-d-v2.0)
#   4. on :status fail — falls back to host Emacs path *unless*
#      --strict-no-emacs is also set, in which case the launcher exits
#      non-zero so CI can flag the cold-init failure.
NELISP_STRICT_NO_EMACS=0
NELISP_NO_EMACS=0
NELISP_STRICT_FILTERED_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --strict-no-emacs)
      NELISP_STRICT_NO_EMACS=1
      NELISP_NO_EMACS=1
      ;;
    --no-emacs)
      NELISP_NO_EMACS=1
      ;;
    *)
      NELISP_STRICT_FILTERED_ARGS+=("$arg")
      ;;
  esac
done

# Phase 7.5.2 cold-init invocation helper.
# Returns 0 when the cold-init coordinator reports :status pass; 1
# otherwise.  Stdout is the coordinator's serialized status plist
# (read by callers for diagnostics).  Stderr is suppressed unless
# NELISP_COLDINIT_VERBOSE=1 in the environment.
run_cold_init() {
  local emacs_bin="$1"
  local src_dir="$2"
  local err_redir="2>/dev/null"
  if [[ "${NELISP_COLDINIT_VERBOSE:-0}" -eq 1 ]]; then
    err_redir=""
  fi
  local result
  result=$(eval "\"$emacs_bin\" --batch -Q -L \"$src_dir\" \
    --eval \"(setq load-prefer-newer t)\" \
    -l nelisp-integration \
    --eval \"(princ (prin1-to-string (nelisp-integration-cold-init-run)))\" \
    $err_redir") || return 1
  # Emit the coordinator plist to stderr so stdout stays reserved
  # for the MCP server's JSON-RPC stream when this function is
  # invoked inside `cmd_mcp_serve'.
  echo "$result" >&2
  echo "$result" | grep -q ":status pass"
  return $?
}

if [[ $NELISP_NO_EMACS -eq 1 ]]; then
  if [[ $NELISP_STRICT_NO_EMACS -eq 1 ]]; then
    echo "anvil: --strict-no-emacs requested (Phase 7.5.2 cold-init coordinator)" >&2
  else
    echo "anvil: --no-emacs requested (Phase 7.5.2 cold-init coordinator + host fallback)" >&2
  fi
  export NELISP_STRICT_NO_EMACS
  export NELISP_NO_EMACS
  # Replace positional args with the filtered list (drop --strict-no-emacs / --no-emacs)
  if [[ ${#NELISP_STRICT_FILTERED_ARGS[@]} -gt 0 ]]; then
    set -- "${NELISP_STRICT_FILTERED_ARGS[@]}"
  else
    set --
  fi
fi

# OS / shell detection (Phase 6.4 Windows support)
ANVIL_OS="linux"
case "$(uname -s 2>/dev/null || echo)" in
  Darwin*)              ANVIL_OS="macos" ;;
  MINGW*|MSYS*|CYGWIN*) ANVIL_OS="windows-msys" ;;
  Linux*)               ANVIL_OS="linux" ;;
  *)                    ANVIL_OS="unknown" ;;
esac
ANVIL_HOME="${ANVIL_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
ANVIL_CONFIG_DIR="${ANVIL_CONFIG_DIR:-$XDG_CONFIG_HOME/anvil}"
ANVIL_CACHE_DIR="${ANVIL_CACHE_DIR:-$XDG_CACHE_HOME/nelisp}"

usage() {
  cat <<EOF
anvil $ANVIL_VERSION — NeLisp-powered MCP tool launcher (Stage D scaffold)

USAGE:
  anvil --version              Show launcher version.
  anvil --help                 Show this help.
  anvil version                Detailed version (os / install root / tools count / emacs).
  anvil doctor                 Diagnose environment (emacs / nelisp / dirs).
  anvil tools-list             List registered MCP tool names (offline, no emacs spawn).
  anvil mcp serve              Start MCP stdio server (Claude Code 接続用).

ENV:
  ANVIL_HOME       Install root (default: auto-detect, $ANVIL_HOME).
  ANVIL_CONFIG_DIR User config dir (default: \$XDG_CONFIG_HOME/anvil).
  ANVIL_CACHE_DIR  State cache dir (default: \$XDG_CACHE_HOME/nelisp).
  EMACS            Emacs binary path (default: auto-detect via PATH).

Stage D Phase 6.0 scaffold — Phase 6.1 で mcp serve 実装完成予定。
詳細: docs/design/18-stage-d-standalone.org
EOF
}

detect_emacs() {
  if [[ -n "${EMACS:-}" ]] && [[ -x "$EMACS" ]]; then
    echo "$EMACS"
    return 0
  fi
  if command -v emacs >/dev/null 2>&1; then
    command -v emacs
    return 0
  fi
  # Windows-specific fallback paths (Phase 6.4).  MSYS / mingw64 ship
  # emacs.exe under /mingw64/bin; native Emacs (gnu.org build) lives
  # under Program Files when launched outside msys.
  if [[ "$ANVIL_OS" == "windows-msys" ]]; then
    for candidate in \
      "/mingw64/bin/emacs.exe" \
      "/c/Program Files/Emacs/emacs-30.1/bin/emacs.exe" \
      "/c/Program Files/Emacs/emacs-29.4/bin/emacs.exe" \
      "/c/Program Files/Emacs/bin/emacs.exe" \
      "/c/msys64/mingw64/bin/emacs.exe" \
    ; do
      if [[ -x "$candidate" ]]; then
        echo "$candidate"
        return 0
      fi
    done
  fi
  # macOS-specific fallback paths (Phase 6.1).  brew Cask installs to
  # /Applications/Emacs.app, brew formula to /opt/homebrew/bin
  # (Apple Silicon) or /usr/local/bin (Intel).  Most users hit `command
  # -v emacs' first, but the Cask app is sometimes not symlinked.
  if [[ "$ANVIL_OS" == "macos" ]]; then
    for candidate in \
      "/Applications/Emacs.app/Contents/MacOS/Emacs" \
      "/opt/homebrew/bin/emacs" \
      "/usr/local/bin/emacs" \
      "/opt/local/bin/emacs" \
    ; do
      if [[ -x "$candidate" ]]; then
        echo "$candidate"
        return 0
      fi
    done
  fi
  echo "error: emacs binary not found. Install Emacs 29+ and retry." >&2
  case "$ANVIL_OS" in
    macos)
      echo "  macOS:    brew install --cask emacs" >&2 ;;
    linux)
      echo "  Debian:   sudo apt install emacs" >&2
      echo "  Fedora:   sudo dnf install emacs" >&2
      echo "  Arch:     sudo pacman -S emacs" >&2 ;;
    windows-msys)
      echo "  msys2:    pacman -S mingw-w64-x86_64-emacs" >&2
      echo "  choco:    choco install emacs" >&2
      echo "  manual:   https://www.gnu.org/software/emacs/download.html" >&2
      echo "  (then re-run this script from an msys2 mingw64 shell)" >&2 ;;
    *)
      echo "  see https://www.gnu.org/software/emacs/" >&2 ;;
  esac
  return 1
}

cmd_doctor() {
  echo "anvil doctor — environment diagnosis"
  echo "  version         : $ANVIL_VERSION"
  echo "  os              : $ANVIL_OS"
  echo "  ANVIL_HOME      : $ANVIL_HOME"
  echo "  config dir      : $ANVIL_CONFIG_DIR $( [[ -d "$ANVIL_CONFIG_DIR" ]] && echo "(exists)" || echo "(not yet)" )"
  echo "  cache dir       : $ANVIL_CACHE_DIR $( [[ -d "$ANVIL_CACHE_DIR" ]] && echo "(exists)" || echo "(not yet)" )"
  if emacs_bin="$(detect_emacs)"; then
    echo "  emacs           : $emacs_bin"
    "$emacs_bin" --version | head -1 | sed 's/^/                    /'
  else
    echo "  emacs           : NOT FOUND"
    return 1
  fi
  local nelisp_src="$ANVIL_HOME/src"
  if [[ -f "$nelisp_src/nelisp-server.el" ]]; then
    echo "  nelisp src      : $nelisp_src (OK)"
  else
    echo "  nelisp src      : $nelisp_src (MISSING — reinstall required)"
    return 1
  fi
  local anvil_dir
  if anvil_dir="$(anvil_lisp_dir)"; then
    echo "  anvil.el        : $anvil_dir (architecture α active)"
    echo "  serve mode      : anvil headless profile (server-id emacs-eval-headless)"
  else
    echo "  anvil.el        : NOT FOUND (set ANVIL_LISP_DIR to enable architecture α)"
    echo "  serve mode      : nelisp-server (fallback, Phase 6.0 baseline)"
  fi
  echo "  status          : ready for 'anvil mcp serve'"
}

cmd_tools_list() {
  # Phase 6.1 — offline tools list.  Greps deftool macro use without
  # spawning an Emacs subprocess, so CI / smoke / docs can confirm the
  # registered surface in <100ms.
  local src_dir="$ANVIL_HOME/src"
  local tools_file="$src_dir/nelisp-tools.el"
  if [[ ! -f "$tools_file" ]]; then
    echo "error: $tools_file not found" >&2
    return 1
  fi
  grep -oE '^\s*\(nelisp-deftool [a-z][a-z0-9-]+' "$tools_file" \
    | awk '{print $2}' | sort -u
}

cmd_version() {
  # Phase 6.1 — rich version subcommand (vs `--version' bare line).
  # Reports launcher version + tools count + install root + emacs ver.
  local src_dir="$ANVIL_HOME/src"
  local tools_count=0
  if [[ -f "$src_dir/nelisp-tools.el" ]]; then
    tools_count=$(cmd_tools_list 2>/dev/null | wc -l | tr -d ' ')
  fi
  echo "anvil $ANVIL_VERSION"
  echo "  os               $ANVIL_OS"
  echo "  install root     $ANVIL_HOME"
  echo "  tools registered $tools_count"
  if emacs_bin="$(detect_emacs 2>/dev/null)"; then
    local emacs_ver
    emacs_ver=$("$emacs_bin" --version 2>/dev/null | head -1)
    echo "  emacs            $emacs_ver"
  else
    echo "  emacs            NOT FOUND (anvil mcp serve will fail)"
  fi
}

## anvil_lisp_dir [internal]
##   Resolve the path to a bundled anvil.el checkout, or empty when
##   absent.  Honour ANVIL_LISP_DIR override (cmd.exe / PowerShell users
##   set it via `set ANVIL_LISP_DIR=C:\path` / `$env:ANVIL_LISP_DIR`,
##   forwarded through bin/anvil.cmd's `set "ANVIL_LISP_DIR=..."`);
##   otherwise probe the conventional locations beside the launcher
##   (anvil-lib/) and the user's dev tree (Notes/dev/anvil.el).
##   Windows (msys2 / Git Bash) candidates use $USERPROFILE when set.
anvil_lisp_dir() {
  # Honour ANVIL_LISP_DIR override.  On Windows the env var may arrive
  # as a backslash path (`C:\path\to\anvil.el`); msys2 / Git Bash bash
  # treats those as foreign — flip to forward slashes for the test.
  if [[ -n "${ANVIL_LISP_DIR:-}" ]]; then
    local lisp_dir="${ANVIL_LISP_DIR//\\//}"
    if [[ -f "$lisp_dir/anvil.el" ]]; then
      printf '%s' "$lisp_dir"
      return 0
    fi
  fi

  # Build candidate list.  Stage D Phase 6.1 tarball layout
  # ($ANVIL_HOME/anvil-lib) covers the ordinary distribution path on
  # every OS — works identically on Linux, macOS, and Windows (msys2).
  local candidates=(
    "$ANVIL_HOME/anvil-lib"
    "$ANVIL_HOME/../anvil.el"
    "$HOME/Notes/dev/anvil.el"
    "$HOME/.emacs.d/external-packages/anvil.el"
  )

  # Windows-only fallback: when running under msys2 / Git Bash,
  # $HOME often differs from %USERPROFILE% (msys home vs Windows
  # home).  Add Windows-native candidates if USERPROFILE is set.
  if [[ -n "${USERPROFILE:-}" ]]; then
    local up="${USERPROFILE//\\//}"
    candidates+=(
      "$up/Notes/dev/anvil.el"
      "$up/.emacs.d/external-packages/anvil.el"
      "$up/AppData/Local/anvil/anvil-lib"
    )
  fi

  local d
  for d in "${candidates[@]}"; do
    if [[ -f "$d/anvil.el" && -f "$d/anvil-server-commands.el" ]]; then
      printf '%s' "$(cd "$d" && pwd)"
      return 0
    fi
  done
  return 1
}

cmd_mcp_serve() {
  local emacs_bin
  emacs_bin="$(detect_emacs)"
  mkdir -p "$ANVIL_CACHE_DIR"
  local src_dir="$ANVIL_HOME/src"

  # Phase 7.5.2 (Doc 32 v2 LOCKED §3.2) — when --no-emacs / --strict-no-emacs
  # was passed, run the cold-init coordinator first.  On :status pass the
  # 4-stage bootstrap is structurally green; in Phase 7.5.2 the actual MCP
  # serve still runs through host Emacs because the static-linked binary
  # lands in Phase 7.5.3 stage-d-v2.0.  --strict-no-emacs surfaces a fail
  # by exiting 1 (CI gate); plain --no-emacs falls back silently.
  if [[ "${NELISP_NO_EMACS:-0}" -eq 1 ]]; then
    if run_cold_init "$emacs_bin" "$src_dir"; then
      echo "anvil: cold-init coordinator green (Phase 7.5.2)" >&2
      echo "anvil: Phase 7.5.2 partial — actual MCP serve via static-linked binary" >&2
      echo "       lands in Phase 7.5.3 (stage-d-v2.0); falling through to host Emacs" >&2
      echo "       path with NELISP_STRICT_NO_EMACS=$NELISP_STRICT_NO_EMACS exported." >&2
    else
      echo "anvil: cold-init coordinator FAIL (Phase 7.5.2)" >&2
      if [[ "${NELISP_STRICT_NO_EMACS:-0}" -eq 1 ]]; then
        echo "       --strict-no-emacs set — exiting 1 (CI / release-qual gate)" >&2
        exit 1
      fi
      echo "       falling back to host Emacs path (--no-emacs non-strict)" >&2
    fi
  fi

  # Stage D Phase 6.1 architecture α: prefer anvil.el headless profile
  # when available (anvil-server delegates to nelisp-* internals via
  # fboundp guard + fallback).  Falls back to nelisp-server only when
  # anvil.el is not bundled / locatable.
  local anvil_dir
  if anvil_dir="$(anvil_lisp_dir)"; then
    if [[ ! -f "$src_dir/nelisp-server.el" ]]; then
      echo "error: nelisp-server.el not found under $src_dir" >&2
      exit 1
    fi
    exec "$emacs_bin" \
      --batch -Q \
      -L "$anvil_dir" \
      -L "$src_dir" \
      --eval "(setq load-prefer-newer t)" \
      --eval "(setenv \"ANVIL_CONFIG_DIR\" \"$ANVIL_CONFIG_DIR\")" \
      --eval "(setenv \"ANVIL_CACHE_DIR\" \"$ANVIL_CACHE_DIR\")" \
      -l anvil-server \
      -l anvil-server-commands \
      -f anvil-server-stage-d-headless-run
  fi

  # Fallback: nelisp-server only (Stage D Phase 6.0 baseline)
  if [[ ! -f "$src_dir/nelisp-server.el" ]]; then
    echo "error: nelisp-server.el not found under $src_dir" >&2
    exit 1
  fi
  exec "$emacs_bin" \
    --batch -Q \
    -L "$src_dir" \
    --eval "(setq load-prefer-newer t)" \
    --eval "(setenv \"ANVIL_CONFIG_DIR\" \"$ANVIL_CONFIG_DIR\")" \
    --eval "(setenv \"ANVIL_CACHE_DIR\" \"$ANVIL_CACHE_DIR\")" \
    -l nelisp-server \
    -l nelisp-tools \
    -f nelisp-server-run-stdio
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi
  case "$1" in
    --version|-v) echo "anvil $ANVIL_VERSION" ;;
    --help|-h) usage ;;
    version) cmd_version ;;
    doctor) cmd_doctor ;;
    tools-list) cmd_tools_list ;;
    mcp)
      shift
      case "${1:-}" in
        serve) cmd_mcp_serve ;;
        *)
          echo "error: unknown mcp subcommand: ${1:-<missing>}" >&2
          echo "  run 'anvil --help' for usage." >&2
          exit 2
          ;;
      esac
      ;;
    *)
      echo "error: unknown command: $1" >&2
      echo "  run 'anvil --help' for usage." >&2
      exit 2
      ;;
  esac
}

main "$@"
