#!/usr/bin/env bash
# anvil — Stage D Phase 6.0 launcher skeleton (bash, pre-Go/Rust port)
#
# Doc 18 Stage D LOCKED 2026-04-25。Option D = Hybrid CLI launcher。
# user config は $XDG_CONFIG_HOME/anvil/ (Doc 18 §2.9)、state DB は
# $XDG_CACHE_HOME/nelisp/nelisp-state.db (Doc 17 §2.2) を想定。
#
# Phase 6.0 時点では Emacs を user install 前提で検出 (Doc 18 §2.5 B)。
# Phase 6.2 (Doc 24) で anvil-http MVP port 完了 (tools/list 33)。
# Phase 6.3 で GitHub Release pipeline、Phase 6.4 で Windows 対応 (msys2
# mingw64 検出 + native Emacs path、bin/anvil.cmd wrapper)。

set -euo pipefail

ANVIL_VERSION="${ANVIL_VERSION:-stage-d-v3.0}"

# OS / shell detection (Phase 6.4 Windows support)
ANVIL_OS="linux"
case "$(uname -s 2>/dev/null || echo)" in
  Darwin*)              ANVIL_OS="macos" ;;
  MINGW*|MSYS*|CYGWIN*) ANVIL_OS="windows-msys" ;;
  Linux*)               ANVIL_OS="linux" ;;
  *)                    ANVIL_OS="unknown" ;;
esac
ANVIL_HOME="${ANVIL_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
ANVIL_CONFIG_DIR="${ANVIL_CONFIG_DIR:-$XDG_CONFIG_HOME/anvil}"
ANVIL_CACHE_DIR="${ANVIL_CACHE_DIR:-$XDG_CACHE_HOME/nelisp}"

usage() {
  cat <<EOF
anvil $ANVIL_VERSION — NeLisp-powered MCP tool launcher (Stage D scaffold)

USAGE:
  anvil --version              Show launcher version.
  anvil --help                 Show this help.
  anvil version                Detailed version (os / install root / tools count / emacs).
  anvil doctor                 Diagnose environment (emacs / nelisp / dirs).
  anvil tools-list             List registered MCP tool names (offline, no emacs spawn).
  anvil mcp serve [--no-emacs|--strict-no-emacs]
                               Start MCP stdio server (Claude Code 接続用).

ENV:
  ANVIL_HOME       Install root (default: auto-detect, $ANVIL_HOME).
  ANVIL_CONFIG_DIR User config dir (default: \$XDG_CONFIG_HOME/anvil).
  ANVIL_CACHE_DIR  State cache dir (default: \$XDG_CACHE_HOME/nelisp).
  EMACS            Emacs binary path (default: auto-detect via PATH).

Stage D Phase 6.0 scaffold — Phase 6.1 で mcp serve 実装完成予定。
詳細: docs/design/18-stage-d-standalone.org
EOF
}

## detect_emacs [internal]
##   Resolution order (Phase 7.5.3 stage-d-v2.0 + earlier fallbacks):
##     1. $EMACS env override (highest priority — dev environments)
##     2. $ANVIL_HOME/emacs/bin/emacs   (bundled emacs from
##        stage-d-v2.0 tarball — preferred when present so
##        `bin/anvil` works on hosts without a system Emacs install)
##     3. Bundled `.exe` variant on Windows (msys2 layout under the
##        tarball)
##     4. command -v emacs (system PATH)
##     5. OS-specific well-known fallbacks (Phase 6.4 retained)
##
##   Backward-compatible: when the bundled binary is absent (= dev
##   checkout, Stage D Phase 6.x tarball without bundled emacs) the
##   resolution falls through to the system-PATH path that has worked
##   since Phase 6.0 — no behaviour change for existing users.
detect_emacs() {
  if [[ -n "${EMACS:-}" ]] && [[ -x "$EMACS" ]]; then
    echo "$EMACS"
    return 0
  fi
  # Phase 7.5.3 stage-d-v2.0 — bundled-emacs preference.  The tarball
  # produced by `make stage-d-v2-tarball` ships a stripped Emacs under
  # `$ANVIL_HOME/emacs/bin/emacs` (POSIX) or
  # `$ANVIL_HOME/emacs/bin/emacs.exe` (msys2 / native Windows).  Prefer
  # it over the system Emacs so a user without `apt install emacs` can
  # still run `bin/anvil`.
  for cand in \
      "$ANVIL_HOME/emacs/bin/emacs" \
      "$ANVIL_HOME/emacs/bin/emacs.exe" \
  ; do
    if [[ -x "$cand" ]]; then
      echo "$cand"
      return 0
    fi
  done
  if command -v emacs >/dev/null 2>&1; then
    command -v emacs
    return 0
  fi
  # Windows-specific fallback paths (Phase 6.4).  MSYS / mingw64 ship
  # emacs.exe under /mingw64/bin; native Emacs (gnu.org build) lives
  # under Program Files when launched outside msys.
  if [[ "$ANVIL_OS" == "windows-msys" ]]; then
    for candidate in \
      "/mingw64/bin/emacs.exe" \
      "/c/Program Files/Emacs/emacs-30.1/bin/emacs.exe" \
      "/c/Program Files/Emacs/emacs-29.4/bin/emacs.exe" \
      "/c/Program Files/Emacs/bin/emacs.exe" \
      "/c/msys64/mingw64/bin/emacs.exe" \
    ; do
      if [[ -x "$candidate" ]]; then
        echo "$candidate"
        return 0
      fi
    done
  fi
  # macOS-specific fallback paths (Phase 6.1).  brew Cask installs to
  # /Applications/Emacs.app, brew formula to /opt/homebrew/bin
  # (Apple Silicon) or /usr/local/bin (Intel).  Most users hit `command
  # -v emacs' first, but the Cask app is sometimes not symlinked.
  if [[ "$ANVIL_OS" == "macos" ]]; then
    for candidate in \
      "/Applications/Emacs.app/Contents/MacOS/Emacs" \
      "/opt/homebrew/bin/emacs" \
      "/usr/local/bin/emacs" \
      "/opt/local/bin/emacs" \
    ; do
      if [[ -x "$candidate" ]]; then
        echo "$candidate"
        return 0
      fi
    done
  fi
  echo "error: emacs binary not found. Install Emacs 29+ and retry." >&2
  case "$ANVIL_OS" in
    macos)
      echo "  macOS:    brew install --cask emacs" >&2 ;;
    linux)
      echo "  Debian:   sudo apt install emacs" >&2
      echo "  Fedora:   sudo dnf install emacs" >&2
      echo "  Arch:     sudo pacman -S emacs" >&2 ;;
    windows-msys)
      echo "  msys2:    pacman -S mingw-w64-x86_64-emacs" >&2
      echo "  choco:    choco install emacs" >&2
      echo "  manual:   https://www.gnu.org/software/emacs/download.html" >&2
      echo "  (then re-run this script from an msys2 mingw64 shell)" >&2 ;;
    *)
      echo "  see https://www.gnu.org/software/emacs/" >&2 ;;
  esac
  return 1
}

anvil_runtime_bin() {
  # Architecture α Wave 3 (2026-04-29) — `anvil-runtime' lives in its
  # own crate now (= `anvil-runtime/target/release/anvil-runtime') so
  # `nelisp-runtime/' stays a pure NeLisp interpreter.  The bundled
  # tarball still ships the binary at the canonical `bin/anvil-runtime'
  # path; dev checkouts pick it up from the new crate's target tree
  # first and fall back to the pre-Wave-3 `nelisp-runtime/target/'
  # location for backward compatibility with un-rebuilt trees.
  local cand
  for cand in \
      "$ANVIL_HOME/bin/anvil-runtime" \
      "$ANVIL_HOME/anvil-runtime/target/release/anvil-runtime" \
      "$ANVIL_HOME/nelisp-runtime/target/release/anvil-runtime" \
  ; do
    if [[ -x "$cand" ]]; then
      printf '%s\n' "$cand"
      return 0
    fi
  done
  printf '%s\n' "$ANVIL_HOME/bin/anvil-runtime"
}

bundled_runtime_present() {
  [[ -x "$ANVIL_HOME/bin/anvil-runtime" ]]
}

nelisp_package_src_dirs() {
  local d
  for d in "$ANVIL_HOME"/packages/*/src; do
    if [[ -d "$d" ]]; then
      printf '%s\n' "$d"
    fi
  done
}

nelisp_find_module_file() {
  local module="$1"
  local src_dir="$ANVIL_HOME/src"
  local path="$src_dir/$module.el"
  if [[ -f "$path" ]]; then
    printf '%s\n' "$path"
    return 0
  fi
  path="$ANVIL_HOME/packages/$module/src/$module.el"
  if [[ -f "$path" ]]; then
    printf '%s\n' "$path"
    return 0
  fi
  return 1
}

runtime_cdylib_path() {
  local cand
  for cand in \
      "$ANVIL_HOME/lib/libnelisp_runtime.so" \
      "$ANVIL_HOME/lib/libnelisp_runtime.dylib" \
      "$ANVIL_HOME/lib/nelisp_runtime.dll" \
      "$ANVIL_HOME/nelisp-runtime/target/release/libnelisp_runtime.so" \
      "$ANVIL_HOME/nelisp-runtime/target/release/libnelisp_runtime.dylib" \
      "$ANVIL_HOME/nelisp-runtime/target/release/nelisp_runtime.dll" \
  ; do
    if [[ -f "$cand" ]]; then
      printf '%s\n' "$cand"
      return 0
    fi
  done
  return 1
}

runtime_env_exec() {
  local runtime_bin="$1"
  local src_dir="$ANVIL_HOME/src"
  local anvil_dir="$ANVIL_HOME/anvil-lib"
  if bundled_runtime_present; then
    export NELISP_SRC_DIR="$src_dir"
    export ANVIL_EL_DIR="$anvil_dir"
    local lib_dir=""
    lib_dir="$(dirname "$(runtime_cdylib_path 2>/dev/null || echo "$ANVIL_HOME/lib/libnelisp_runtime.so")")"
    case "$ANVIL_OS" in
      macos)
        export DYLD_LIBRARY_PATH="${lib_dir}${DYLD_LIBRARY_PATH:+:$DYLD_LIBRARY_PATH}"
        ;;
      windows-msys)
        export PATH="${lib_dir}${PATH:+:$PATH}"
        ;;
      *)
        export LD_LIBRARY_PATH="${lib_dir}${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
        ;;
    esac
  fi
  exec "$runtime_bin" mcp serve
}

cmd_doctor() {
  echo "anvil doctor — environment diagnosis"
  echo "  version         : $ANVIL_VERSION"
  echo "  os              : $ANVIL_OS"
  echo "  ANVIL_HOME      : $ANVIL_HOME"
  echo "  config dir      : $ANVIL_CONFIG_DIR $( [[ -d "$ANVIL_CONFIG_DIR" ]] && echo "(exists)" || echo "(not yet)" )"
  echo "  cache dir       : $ANVIL_CACHE_DIR $( [[ -d "$ANVIL_CACHE_DIR" ]] && echo "(exists)" || echo "(not yet)" )"
  if bundled_runtime_present; then
    echo "  mode            : v3.0 standalone (= no emacs)"
    echo "  emacs           : NOT NEEDED (v3.0 standalone)"
  elif emacs_bin="$(detect_emacs 2>/dev/null)"; then
    local emacs_source="system"
    case "$emacs_bin" in
      "$ANVIL_HOME/emacs/bin/emacs"|"$ANVIL_HOME/emacs/bin/emacs.exe")
        emacs_source="bundled (stage-d-v2.0)" ;;
    esac
    echo "  emacs           : $emacs_bin [$emacs_source]"
    "$emacs_bin" --version | head -1 | sed 's/^/                    /'
  else
    echo "  emacs           : NOT FOUND"
    return 1
  fi
  local nelisp_src="$ANVIL_HOME/src"
  echo "  nelisp src      : $nelisp_src + packages/*/src"
  local anvil_dir
  if bundled_runtime_present && [[ -f "$ANVIL_HOME/anvil-lib/anvil-host.el" ]]; then
    echo "  anvil.el        : $ANVIL_HOME/anvil-lib (bundled runtime subset)"
    echo "  serve mode      : Rust runtime + bundled anvil-host subset"
  elif anvil_dir="$(anvil_lisp_dir)"; then
    echo "  anvil.el        : $anvil_dir (architecture α active)"
    echo "  serve mode      : anvil headless profile (server-id emacs-eval-headless)"
  else
    echo "  anvil.el        : NOT FOUND (set ANVIL_LISP_DIR or install anvil.el)"
    echo "  serve mode      : unavailable — anvil.el required"
    return 1
  fi
  if ! bundled_runtime_present; then
    # Phase 7.5.1 (Doc 32 v2 LOCKED §3.1) — surface the cdylib +
    # staticlib build artifacts so a user can confirm whether their
    # checkout has produced the static-link prerequisites for the
    # upcoming `--no-emacs` (Phase 7.5.2) / stage-d-v2.0 (Phase 7.5.3)
    # paths without grepping the Cargo target dir manually.
    local rt_dir="$ANVIL_HOME/nelisp-runtime/target/release"
    local rt_cdylib=""
    for cand in libnelisp_runtime.so libnelisp_runtime.dylib nelisp_runtime.dll; do
      if [[ -f "$rt_dir/$cand" ]]; then
        rt_cdylib="$rt_dir/$cand"
        break
      fi
    done
    if [[ -n "$rt_cdylib" ]]; then
      local sz
      sz=$(du -h "$rt_cdylib" 2>/dev/null | cut -f1)
      echo "  runtime cdylib  : $rt_cdylib ($sz)"
    else
      echo "  runtime cdylib  : NOT BUILT — run 'make runtime'"
    fi
    local rt_static="$rt_dir/libnelisp_runtime.a"
    if [[ -f "$rt_static" ]]; then
      local sz
      sz=$(du -h "$rt_static" 2>/dev/null | cut -f1)
      echo "  runtime static  : $rt_static ($sz)"
    else
      echo "  runtime static  : NOT BUILT — run 'make runtime-static'"
    fi
  fi
  local runtime_bin
  runtime_bin="$(anvil_runtime_bin)"
  if [[ -x "$runtime_bin" ]]; then
    echo "  rust runtime    : $runtime_bin [present]"
    if bundled_runtime_present; then
      local rt_cdylib
      if rt_cdylib="$(runtime_cdylib_path 2>/dev/null)"; then
        echo "  runtime cdylib  : $rt_cdylib ($(du -h "$rt_cdylib" 2>/dev/null | cut -f1))"
      fi
      echo "  startup path    : default = Rust runtime (no emacs subprocess)"
    fi
  else
    echo "  rust runtime    : $runtime_bin [absent]"
  fi
  echo "  status          : ready for 'anvil mcp serve'"
}

cmd_tools_list() {
  # Architecture α offline tools list.  Greps `:id "..."' from
  # `anvil-server-register-tool' calls in anvil.el so CI / smoke /
  # docs can confirm the registered surface without spawning Emacs.
  local anvil_dir
  if ! anvil_dir="$(anvil_lisp_dir)"; then
    echo "error: anvil.el not found (set ANVIL_LISP_DIR)" >&2
    return 1
  fi
  grep -hE '^\s*:id\s+"[a-z][a-z0-9-]+"' "$anvil_dir"/anvil*.el 2>/dev/null \
    | sed -E 's/^\s*:id\s+"([^"]+)".*/\1/' | sort -u
}

cmd_version() {
  # Phase 6.1 — rich version subcommand (vs `--version' bare line).
  # Reports launcher version + tools count + install root + emacs ver.
  # Phase 7.5.3 — also classifies emacs source as `bundled' (from
  # stage-d-v2.0 tarball) or `system' so a user knows whether they are
  # depending on a host install or the bundled fallback.
  local tools_count=0
  if anvil_lisp_dir >/dev/null 2>&1; then
    tools_count=$(cmd_tools_list 2>/dev/null | wc -l | tr -d ' ')
  fi
  echo "anvil $ANVIL_VERSION"
  echo "  os               $ANVIL_OS"
  echo "  install root     $ANVIL_HOME"
  echo "  tools registered $tools_count"
  if bundled_runtime_present; then
    echo "  mode             v3.0 standalone (= no emacs)"
    echo "  emacs            NOT NEEDED (v3.0 standalone)"
  elif emacs_bin="$(detect_emacs 2>/dev/null)"; then
    local emacs_ver emacs_source="system"
    emacs_ver=$("$emacs_bin" --version 2>/dev/null | head -1)
    case "$emacs_bin" in
      "$ANVIL_HOME/emacs/bin/emacs"|"$ANVIL_HOME/emacs/bin/emacs.exe")
        emacs_source="bundled" ;;
    esac
    echo "  emacs            $emacs_ver ($emacs_source)"
    echo "  emacs path       $emacs_bin"
  else
    echo "  emacs            NOT FOUND (anvil mcp serve will fail)"
  fi
  local runtime_bin
  runtime_bin="$(anvil_runtime_bin)"
  if [[ -x "$runtime_bin" ]]; then
    echo "  rust runtime     $runtime_bin [present]"
    if bundled_runtime_present; then
      echo "  runtime path     $runtime_bin"
    fi
  else
    echo "  rust runtime     $runtime_bin [absent]"
  fi
}

## anvil_lisp_dir [internal]
##   Resolve the path to a bundled anvil.el checkout, or empty when
##   absent.  Honour ANVIL_LISP_DIR override (cmd.exe / PowerShell users
##   set it via `set ANVIL_LISP_DIR=C:\path` / `$env:ANVIL_LISP_DIR`,
##   forwarded through bin/anvil.cmd's `set "ANVIL_LISP_DIR=..."`);
##   otherwise probe the conventional locations beside the launcher
##   (anvil-lib/) and the user's dev tree (Notes/dev/anvil.el).
##   Windows (msys2 / Git Bash) candidates use $USERPROFILE when set.
anvil_lisp_dir() {
  # Honour ANVIL_LISP_DIR override.  On Windows the env var may arrive
  # as a backslash path (`C:\path\to\anvil.el`); msys2 / Git Bash bash
  # treats those as foreign — flip to forward slashes for the test.
  if [[ -n "${ANVIL_LISP_DIR:-}" ]]; then
    local lisp_dir="${ANVIL_LISP_DIR//\\//}"
    if [[ -f "$lisp_dir/anvil.el" ]]; then
      printf '%s' "$lisp_dir"
      return 0
    fi
  fi

  # Build candidate list.  Stage D Phase 6.1 tarball layout
  # ($ANVIL_HOME/anvil-lib) covers the ordinary distribution path on
  # every OS — works identically on Linux, macOS, and Windows (msys2).
  local candidates=(
    "$ANVIL_HOME/anvil-lib"
    "$ANVIL_HOME/../anvil.el"
    "$HOME/Notes/dev/anvil.el"
    "$HOME/.emacs.d/external-packages/anvil.el"
  )

  # Windows-only fallback: when running under msys2 / Git Bash,
  # $HOME often differs from %USERPROFILE% (msys home vs Windows
  # home).  Add Windows-native candidates if USERPROFILE is set.
  if [[ -n "${USERPROFILE:-}" ]]; then
    local up="${USERPROFILE//\\//}"
    candidates+=(
      "$up/Notes/dev/anvil.el"
      "$up/.emacs.d/external-packages/anvil.el"
      "$up/AppData/Local/anvil/anvil-lib"
    )
  fi

  local d
  for d in "${candidates[@]}"; do
    if [[ -f "$d/anvil.el" && -f "$d/anvil-server-commands.el" ]]; then
      printf '%s' "$(cd "$d" && pwd)"
      return 0
    fi
  done
  return 1
}

cmd_mcp_serve() {
  local no_emacs=0
  local strict_no_emacs=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-emacs)
        no_emacs=1
        shift
        ;;
      --strict-no-emacs)
        strict_no_emacs=1
        no_emacs=1
        shift
        ;;
      *)
        echo "error: unknown argument for 'anvil mcp serve': $1" >&2
        echo "  supported flags: --no-emacs, --strict-no-emacs" >&2
        exit 2
        ;;
    esac
  done

  mkdir -p "$ANVIL_CACHE_DIR"
  local runtime_bin
  runtime_bin="$(anvil_runtime_bin)"
  if [[ $no_emacs -eq 0 ]] && bundled_runtime_present && [[ -x "$runtime_bin" ]]; then
    runtime_env_exec "$runtime_bin"
  fi
  if [[ $no_emacs -eq 1 ]]; then
    if [[ -x "$runtime_bin" ]]; then
      if [[ $strict_no_emacs -eq 1 ]]; then
        echo "anvil: --strict-no-emacs requested; dispatching to Rust runtime" >&2
      else
        echo "anvil: --no-emacs requested; dispatching to Rust runtime" >&2
      fi
      runtime_env_exec "$runtime_bin"
    fi
    echo "error: rust runtime binary missing: $runtime_bin" >&2
    echo "  build with: make runtime-static && (cd anvil-runtime && cargo build --release)" >&2
    exit 1
  fi

  local emacs_bin
  emacs_bin="$(detect_emacs)"
  local src_dir="$ANVIL_HOME/src"
  local package_dir
  local emacs_load_args=()
  for package_dir in $(nelisp_package_src_dirs); do
    emacs_load_args+=(-L "$package_dir")
  done

  # Stage D Phase 6.1 architecture α: anvil.el headless profile is the
  # sole serve mode.  anvil-server delegates to nelisp-* internals via
  # fboundp guard + fallback; the legacy nelisp-server fallback path
  # was removed once architecture α stabilised (anvil functionality
  # lives only on the anvil.el side, NeLisp packages stay pure
  # substrate libraries).
  local anvil_dir
  if ! anvil_dir="$(anvil_lisp_dir)"; then
    echo "error: anvil.el not found — set ANVIL_LISP_DIR or install anvil.el" >&2
    exit 1
  fi
  exec "$emacs_bin" \
    --batch -Q \
    -L "$anvil_dir" \
    -L "$src_dir" \
    "${emacs_load_args[@]}" \
    --eval "(setq load-prefer-newer t)" \
    --eval "(setenv \"ANVIL_CONFIG_DIR\" \"$ANVIL_CONFIG_DIR\")" \
    --eval "(setenv \"ANVIL_CACHE_DIR\" \"$ANVIL_CACHE_DIR\")" \
    -l anvil-server \
    -l anvil-server-commands \
    -f anvil-server-stage-d-headless-run
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi
  case "$1" in
    --version|-v) echo "anvil $ANVIL_VERSION" ;;
    --help|-h) usage ;;
    version) cmd_version ;;
    doctor) cmd_doctor ;;
    tools-list) cmd_tools_list ;;
    mcp)
      shift
      case "${1:-}" in
        serve)
          shift
          cmd_mcp_serve "$@"
          ;;
        *)
          echo "error: unknown mcp subcommand: ${1:-<missing>}" >&2
          echo "  run 'anvil --help' for usage." >&2
          exit 2
          ;;
      esac
      ;;
    *)
      echo "error: unknown command: $1" >&2
      echo "  run 'anvil --help' for usage." >&2
      exit 2
      ;;
  esac
}

main "$@"
