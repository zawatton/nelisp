#!/usr/bin/env bash
# anvil — Stage D Phase 6.0 launcher skeleton (bash, pre-Go/Rust port)
#
# Doc 18 Stage D LOCKED 2026-04-25。Option D = Hybrid CLI launcher。
# user config は $XDG_CONFIG_HOME/anvil/ (Doc 18 §2.9)、state DB は
# $XDG_CACHE_HOME/nelisp/nelisp-state.db (Doc 17 §2.2) を想定。
#
# Phase 6.0 時点では Emacs を user install 前提で検出 (Doc 18 §2.5 B)。
# Phase 6.2 (Doc 24) で anvil-http MVP port 完了 (tools/list 33)。
# Phase 6.3 で GitHub Release pipeline、Phase 6.4 で Windows 対応 (msys2
# mingw64 検出 + native Emacs path、bin/anvil.cmd wrapper)。

set -euo pipefail

ANVIL_VERSION="stage-d-v0.2-pre"

# OS / shell detection (Phase 6.4 Windows support)
ANVIL_OS="linux"
case "$(uname -s 2>/dev/null || echo)" in
  Darwin*)              ANVIL_OS="macos" ;;
  MINGW*|MSYS*|CYGWIN*) ANVIL_OS="windows-msys" ;;
  Linux*)               ANVIL_OS="linux" ;;
  *)                    ANVIL_OS="unknown" ;;
esac
ANVIL_HOME="${ANVIL_HOME:-$(cd "$(dirname "$0")/.." && pwd)}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
ANVIL_CONFIG_DIR="${ANVIL_CONFIG_DIR:-$XDG_CONFIG_HOME/anvil}"
ANVIL_CACHE_DIR="${ANVIL_CACHE_DIR:-$XDG_CACHE_HOME/nelisp}"

usage() {
  cat <<EOF
anvil $ANVIL_VERSION — NeLisp-powered MCP tool launcher (Stage D scaffold)

USAGE:
  anvil --version              Show launcher version.
  anvil --help                 Show this help.
  anvil version                Detailed version (os / install root / tools count / emacs).
  anvil doctor                 Diagnose environment (emacs / nelisp / dirs).
  anvil tools-list             List registered MCP tool names (offline, no emacs spawn).
  anvil mcp serve              Start MCP stdio server (Claude Code 接続用).

ENV:
  ANVIL_HOME       Install root (default: auto-detect, $ANVIL_HOME).
  ANVIL_CONFIG_DIR User config dir (default: \$XDG_CONFIG_HOME/anvil).
  ANVIL_CACHE_DIR  State cache dir (default: \$XDG_CACHE_HOME/nelisp).
  EMACS            Emacs binary path (default: auto-detect via PATH).

Stage D Phase 6.0 scaffold — Phase 6.1 で mcp serve 実装完成予定。
詳細: docs/design/18-stage-d-standalone.org
EOF
}

detect_emacs() {
  if [[ -n "${EMACS:-}" ]] && [[ -x "$EMACS" ]]; then
    echo "$EMACS"
    return 0
  fi
  if command -v emacs >/dev/null 2>&1; then
    command -v emacs
    return 0
  fi
  # Windows-specific fallback paths (Phase 6.4).  MSYS / mingw64 ship
  # emacs.exe under /mingw64/bin; native Emacs (gnu.org build) lives
  # under Program Files when launched outside msys.
  if [[ "$ANVIL_OS" == "windows-msys" ]]; then
    for candidate in \
      "/mingw64/bin/emacs.exe" \
      "/c/Program Files/Emacs/emacs-30.1/bin/emacs.exe" \
      "/c/Program Files/Emacs/emacs-29.4/bin/emacs.exe" \
      "/c/Program Files/Emacs/bin/emacs.exe" \
      "/c/msys64/mingw64/bin/emacs.exe" \
    ; do
      if [[ -x "$candidate" ]]; then
        echo "$candidate"
        return 0
      fi
    done
  fi
  # macOS-specific fallback paths (Phase 6.1).  brew Cask installs to
  # /Applications/Emacs.app, brew formula to /opt/homebrew/bin
  # (Apple Silicon) or /usr/local/bin (Intel).  Most users hit `command
  # -v emacs' first, but the Cask app is sometimes not symlinked.
  if [[ "$ANVIL_OS" == "macos" ]]; then
    for candidate in \
      "/Applications/Emacs.app/Contents/MacOS/Emacs" \
      "/opt/homebrew/bin/emacs" \
      "/usr/local/bin/emacs" \
      "/opt/local/bin/emacs" \
    ; do
      if [[ -x "$candidate" ]]; then
        echo "$candidate"
        return 0
      fi
    done
  fi
  echo "error: emacs binary not found. Install Emacs 29+ and retry." >&2
  case "$ANVIL_OS" in
    macos)
      echo "  macOS:    brew install --cask emacs" >&2 ;;
    linux)
      echo "  Debian:   sudo apt install emacs" >&2
      echo "  Fedora:   sudo dnf install emacs" >&2
      echo "  Arch:     sudo pacman -S emacs" >&2 ;;
    windows-msys)
      echo "  msys2:    pacman -S mingw-w64-x86_64-emacs" >&2
      echo "  choco:    choco install emacs" >&2
      echo "  manual:   https://www.gnu.org/software/emacs/download.html" >&2
      echo "  (then re-run this script from an msys2 mingw64 shell)" >&2 ;;
    *)
      echo "  see https://www.gnu.org/software/emacs/" >&2 ;;
  esac
  return 1
}

cmd_doctor() {
  echo "anvil doctor — environment diagnosis"
  echo "  version         : $ANVIL_VERSION"
  echo "  os              : $ANVIL_OS"
  echo "  ANVIL_HOME      : $ANVIL_HOME"
  echo "  config dir      : $ANVIL_CONFIG_DIR $( [[ -d "$ANVIL_CONFIG_DIR" ]] && echo "(exists)" || echo "(not yet)" )"
  echo "  cache dir       : $ANVIL_CACHE_DIR $( [[ -d "$ANVIL_CACHE_DIR" ]] && echo "(exists)" || echo "(not yet)" )"
  if emacs_bin="$(detect_emacs)"; then
    echo "  emacs           : $emacs_bin"
    "$emacs_bin" --version | head -1 | sed 's/^/                    /'
  else
    echo "  emacs           : NOT FOUND"
    return 1
  fi
  local nelisp_src="$ANVIL_HOME/src"
  if [[ -f "$nelisp_src/nelisp-server.el" ]]; then
    echo "  nelisp src      : $nelisp_src (OK)"
  else
    echo "  nelisp src      : $nelisp_src (MISSING — reinstall required)"
    return 1
  fi
  echo "  status          : ready for 'anvil mcp serve'"
}

cmd_tools_list() {
  # Phase 6.1 — offline tools list.  Greps deftool macro use without
  # spawning an Emacs subprocess, so CI / smoke / docs can confirm the
  # registered surface in <100ms.
  local src_dir="$ANVIL_HOME/src"
  local tools_file="$src_dir/nelisp-tools.el"
  if [[ ! -f "$tools_file" ]]; then
    echo "error: $tools_file not found" >&2
    return 1
  fi
  grep -oE '^\s*\(nelisp-deftool [a-z][a-z0-9-]+' "$tools_file" \
    | awk '{print $2}' | sort -u
}

cmd_version() {
  # Phase 6.1 — rich version subcommand (vs `--version' bare line).
  # Reports launcher version + tools count + install root + emacs ver.
  local src_dir="$ANVIL_HOME/src"
  local tools_count=0
  if [[ -f "$src_dir/nelisp-tools.el" ]]; then
    tools_count=$(cmd_tools_list 2>/dev/null | wc -l | tr -d ' ')
  fi
  echo "anvil $ANVIL_VERSION"
  echo "  os               $ANVIL_OS"
  echo "  install root     $ANVIL_HOME"
  echo "  tools registered $tools_count"
  if emacs_bin="$(detect_emacs 2>/dev/null)"; then
    local emacs_ver
    emacs_ver=$("$emacs_bin" --version 2>/dev/null | head -1)
    echo "  emacs            $emacs_ver"
  else
    echo "  emacs            NOT FOUND (anvil mcp serve will fail)"
  fi
}

cmd_mcp_serve() {
  local emacs_bin
  emacs_bin="$(detect_emacs)"
  mkdir -p "$ANVIL_CACHE_DIR"
  local src_dir="$ANVIL_HOME/src"
  if [[ ! -f "$src_dir/nelisp-server.el" ]]; then
    echo "error: nelisp-server.el not found under $src_dir" >&2
    exit 1
  fi
  exec "$emacs_bin" \
    --batch -Q \
    -L "$src_dir" \
    --eval "(setq load-prefer-newer t)" \
    --eval "(setenv \"ANVIL_CONFIG_DIR\" \"$ANVIL_CONFIG_DIR\")" \
    --eval "(setenv \"ANVIL_CACHE_DIR\" \"$ANVIL_CACHE_DIR\")" \
    -l nelisp-server \
    -l nelisp-tools \
    -f nelisp-server-run-stdio
}

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi
  case "$1" in
    --version|-v) echo "anvil $ANVIL_VERSION" ;;
    --help|-h) usage ;;
    version) cmd_version ;;
    doctor) cmd_doctor ;;
    tools-list) cmd_tools_list ;;
    mcp)
      shift
      case "${1:-}" in
        serve) cmd_mcp_serve ;;
        *)
          echo "error: unknown mcp subcommand: ${1:-<missing>}" >&2
          echo "  run 'anvil --help' for usage." >&2
          exit 2
          ;;
      esac
      ;;
    *)
      echo "error: unknown command: $1" >&2
      echo "  run 'anvil --help' for usage." >&2
      exit 2
      ;;
  esac
}

main "$@"
