#!/usr/bin/env bash
# Phase B5 Final B Stage 2 (= 2026-05-09) — pure-shell `anvil-runtime'.
# Replaces the prior Rust `anvil-runtime' binary (= 5,667 LOC carved
# out into the now-deleted `anvil-runtime/' workspace crate).  The
# launcher loads anvil-server.el modules under standalone NeLisp and
# enters the MCP Content-Length stdio loop via
# `scripts/anvil-runtime-shell-loop.el'.
#
# Required env / paths:
#   NELISP_BIN          — nelisp standalone binary (default: derived
#                         from this script's location → ../target/release/nelisp)
#   NELISP_EMACS_DIR    — nelisp-emacs checkout root (default:
#                         derived from script-dir's sibling)
#   ANVIL_EL_DIR        — anvil.el checkout root (= where
#                         anvil-server.el lives)
#   ANVIL_SERVER_ID     — server-id (default: "default")

set -euo pipefail

ANVIL_RUNTIME_VERSION="0.6.0-nelisp-shell"

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

NELISP_BIN="${NELISP_BIN:-$script_dir/../target/release/nelisp}"
NELISP_EMACS_DIR="${NELISP_EMACS_DIR:-$(cd "$script_dir/../../nelisp-emacs" 2>/dev/null && pwd || true)}"
LOOP_EL="${LOOP_EL:-$NELISP_EMACS_DIR/scripts/anvil-runtime-shell-loop.el}"

usage() {
    cat >&2 <<EOF
usage: anvil-runtime --version
       anvil-runtime mcp serve
EOF
    exit 2
}

if [ "$#" -lt 1 ]; then
    usage
fi

case "$1" in
    --version)
        echo "anvil-runtime $ANVIL_RUNTIME_VERSION"
        exit 0
        ;;
    mcp)
        if [ "$#" -ge 2 ] && [ "$2" = "serve" ]; then
            if [ ! -x "$NELISP_BIN" ]; then
                echo "anvil-runtime: nelisp binary not found at $NELISP_BIN" >&2
                exit 1
            fi
            if [ ! -f "$LOOP_EL" ]; then
                echo "anvil-runtime: loop driver not found at $LOOP_EL" >&2
                exit 1
            fi
            exec "$NELISP_BIN" exec "$LOOP_EL"
        fi
        usage
        ;;
    *)
        usage
        ;;
esac
