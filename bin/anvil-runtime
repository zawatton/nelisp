#!/usr/bin/env bash
# Phase B5 Final B Stage 2 (= 2026-05-09) — pure-shell `anvil-runtime'.
# Replaces the prior Rust `anvil-runtime' binary (= 5,667 LOC carved
# out into the now-deleted `anvil-runtime/' workspace crate).  The
# launcher loads anvil-server.el modules under standalone NeLisp and
# enters the MCP Content-Length stdio loop via
# `scripts/anvil-runtime-shell-loop.el'.
#
# Required env / paths:
#   NELISP_BIN          — nelisp standalone binary (default: derived
#                         from this script's location → ../target/release/nelisp)
#   NELISP_EMACS_DIR    — nelisp-emacs checkout root (default:
#                         derived from script-dir's sibling)
#   ANVIL_EL_DIR        — anvil.el checkout root (= where
#                         anvil-server.el lives)
#   ANVIL_SERVER_ID     — server-id (default: "default")

set -euo pipefail

ANVIL_RUNTIME_VERSION="0.6.0-nelisp-shell"

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

NELISP_BIN="${NELISP_BIN:-$script_dir/../target/release/nelisp}"
NELISP_EMACS_DIR="${NELISP_EMACS_DIR:-$(cd "$script_dir/../../nelisp-emacs" 2>/dev/null && pwd || true)}"
LOOP_EL="${LOOP_EL:-$NELISP_EMACS_DIR/scripts/anvil-runtime-shell-loop.el}"
SERVER_LOOP_EL="${SERVER_LOOP_EL:-$NELISP_EMACS_DIR/scripts/anvil-runtime-server-loop.el}"

usage() {
    cat >&2 <<EOF
usage: anvil-runtime --version
       anvil-runtime mcp serve              (Phase B5 stdio loop, single-client)
       anvil-runtime server [SOCKET_PATH]   (K2 UNIX-socket loop, multi-client)
EOF
    exit 2
}

if [ "$#" -lt 1 ]; then
    usage
fi

case "$1" in
    --version)
        echo "anvil-runtime $ANVIL_RUNTIME_VERSION"
        exit 0
        ;;
    mcp)
        if [ "$#" -ge 2 ] && [ "$2" = "serve" ]; then
            if [ ! -x "$NELISP_BIN" ]; then
                echo "anvil-runtime: nelisp binary not found at $NELISP_BIN" >&2
                exit 1
            fi
            if [ ! -f "$LOOP_EL" ]; then
                echo "anvil-runtime: loop driver not found at $LOOP_EL" >&2
                exit 1
            fi
            exec "$NELISP_BIN" exec "$LOOP_EL"
        fi
        usage
        ;;
    server)
        if [ ! -x "$NELISP_BIN" ]; then
            echo "anvil-runtime: nelisp binary not found at $NELISP_BIN" >&2
            exit 1
        fi
        if [ ! -f "$SERVER_LOOP_EL" ]; then
            echo "anvil-runtime: server loop not found at $SERVER_LOOP_EL" >&2
            exit 1
        fi
        # NeLisp Phase 1.6's `getenv' is a stub returning nil; we cannot
        # pass the socket path via OS env.  Synthesise a tiny bootstrap
        # elisp file that `setq's the path and then loads the real
        # server loop.  The file lives next to the socket itself so
        # `anvil-runtime-daemon stop' cleans it up alongside the socket.
        SOCKET_PATH="${2:-$HOME/.anvil-runtime/sock}"
        SOCKET_DIR="$(dirname "$SOCKET_PATH")"
        mkdir -p "$SOCKET_DIR"
        BOOTSTRAP="$SOCKET_DIR/bootstrap.el"
        cat > "$BOOTSTRAP" <<EOF
;; anvil-runtime server bootstrap (auto-generated by bin/anvil-runtime)
(setq anvil-runtime-bootstrap-socket-path "$SOCKET_PATH")
(load "$SERVER_LOOP_EL" nil t)
EOF
        exec "$NELISP_BIN" exec "$BOOTSTRAP"
        ;;
    *)
        usage
        ;;
esac
