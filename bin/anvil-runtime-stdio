#!/usr/bin/env bash
# anvil-runtime-stdio — MCP-stdio ↔ UNIX-socket bridge for the
# persistent anvil-runtime daemon.  K2 v2 (2026-05-11) — uses `socat'
# to relay each MCP client session over the daemon's `~/.anvil-runtime/sock'.
# Multi-client concurrent: N MCP clients can run at once, each getting
# their own connection process inside the standalone NeLisp registry.
#
# Drop-in for `.mcp.json':
#   {"mcpServers":{"anvil-standalone":{"command":"<...>/anvil-runtime-stdio"}}}
#
# Setup:
#   1. Start the daemon (cold-load ~5-7 min, one-time):
#        bin/anvil-runtime-daemon start
#   2. Wait for `pre-loop registry keys=...' to appear in the log:
#        bin/anvil-runtime-daemon logs
#   3. Wire `.mcp.json' as above and start the MCP client.

set -eu -o pipefail

DIR="${ANVIL_RUNTIME_DAEMON_DIR:-$HOME/.anvil-runtime}"
SOCKET="$DIR/sock"
PID_FILE="$DIR/daemon.pid"

if [ ! -S "$SOCKET" ] ; then
    echo "anvil-runtime-stdio: socket missing — start the daemon first:" >&2
    echo "    $(dirname "$0")/anvil-runtime-daemon start" >&2
    exit 1
fi

if [ -f "$PID_FILE" ] && ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null ; then
    echo "anvil-runtime-stdio: daemon process is dead (pid $(cat "$PID_FILE")). Restart:" >&2
    echo "    $(dirname "$0")/anvil-runtime-daemon restart" >&2
    exit 1
fi

# Prefer socat if available (= more featureful, half-close handling),
# fall back to OpenBSD `nc -U' (= ships with Debian / Ubuntu / most
# distros by default and supports UNIX-domain sockets via `-U').
if command -v socat >/dev/null 2>&1 ; then
    exec socat -T 0 STDIO UNIX-CONNECT:"$SOCKET"
elif command -v nc >/dev/null 2>&1 ; then
    # `-N' = shutdown peer on stdin EOF (OpenBSD-nc only).  We try with
    # it first since that matches the MCP client-closes-stdin lifecycle;
    # if the local `nc' does not recognise `-N' (= traditional nc on
    # Alpine etc.), fall back without it.
    if nc -h 2>&1 | grep -q -- '-N' ; then
        exec nc -U -N "$SOCKET"
    else
        exec nc -U "$SOCKET"
    fi
else
    echo "anvil-runtime-stdio: need \`socat' or OpenBSD \`nc' for UNIX-socket bridge" >&2
    exit 1
fi
